# Voice AI Eval Harness — environment variables
# Copy to .env and fill in your credentials.

# ── Vapi ──────────────────────────────────────────────────────────────────────
VAPI_API_KEY=

# ── Retell ────────────────────────────────────────────────────────────────────
RETELL_API_KEY=

# ── OpenAI (used only by scripts/seed_audio.py to generate WAV fixtures) ──────
OPENAI_API_KEY=

# ── Harness settings ──────────────────────────────────────────────────────────
# Public base URL where the harness webhook receiver is reachable.
# On Replit this is set automatically; override for local runs behind ngrok.
# Example: https://your-tunnel.ngrok.io
HARNESS_PUBLIC_URL=

# SQLite DB path (default: ./results.db)
DATABASE_URL=sqlite:///./results.db

# Default trials per scenario per platform
TRIALS=10

# Max requests per minute to each platform API (built-in backoff respects this)
RATE_LIMIT_RPM=10
